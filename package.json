    "@performanc/voice": "github:PerformanC/voice",
    "@wasm-audio-decoders/flac": "^0.2.10",
    "@wasm-audio-decoders/ogg-vorbis": "^0.1.20",
    "mp4box": "^2.3.0",
    "mpg123-decoder": "^1.0.3",
    "myzod": "^1.12.1",
    "sodium-native": "^5.0.10",
